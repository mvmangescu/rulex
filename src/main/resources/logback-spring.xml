<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Registers %clr, %wex, %wEx and other Spring Boot conversion words -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Provides %clr, %wEx and the standard Spring Boot pattern variables -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ─── Dev: coloured console — matches Spring Boot's default layout ──── -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr([%-15.15X{requestId:-no-id}]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ─── Prod: structured JSON for log aggregators ────────────────────── -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeCallerData>false</includeCallerData>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <customFields>{"service":"blockchain-engine"}</customFields>
                <fieldNames>
                    <timestamp>time</timestamp>
                    <version>[ignore]</version>
                </fieldNames>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="org.hibernate"           level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
    </springProfile>
</configuration>
