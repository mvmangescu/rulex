The grammar should parse all of the following without error:

age > 18
age > 18 AND active = true
age > 18 OR vip = true
NOT active = true
(age > 18 AND score > 50) OR vip = true
status IN ('active', 'pending', 'trial')
role NOT IN ('banned', 'suspended')
name CONTAINS 'oh'
tags NOT CONTAINS 'legacy'
email IS NULL
email IS NOT NULL
score IS NUMERIC
abs(balance) > 100
length(name) >= 3
upper(status) = 'ACTIVE'
age > 18 AND active = true OR vip = true
score * 1.1 + bonus >= 90
price / 2 > 10
value % 3 = 0
-score < 0
name = 'O''Brien'
name = "O'Brien"
flag = true
missing = null
age >= 18 AND age <= 65
length(tags) > 0 AND tags CONTAINS 'java'